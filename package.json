{
  "name": "mobiscroll-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build && node scripts/strip-jsx.js",
    "build-staging": "docusaurus build --config docusaurus.config.staging.js && node scripts/strip-jsx.js",
    "build-dev": "docusaurus build --config docusaurus.config.dev.js && node scripts/strip-jsx.js",
    "build-localdev": "docusaurus build --config docusaurus.config.localdev.js && node scripts/strip-jsx.js",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "dev": "docusaurus start --config docusaurus.config.localhost.js",
    "check": "npm run build && npm run serve",
    "descriptions:add": "node scripts/add-descriptions.js",
    "descriptions:validate": "node scripts/validate-descriptions.js"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/plugin-content-docs": "^3.10.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@img-comparison-slider/react": "^8.0.1",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^1.2.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.0",
    "@docusaurus/tsconfig": "^3.10.0",
    "@docusaurus/types": "^3.10.0",
    "docusaurus-plugin-llms": "^0.3.0",
    "typescript": "^5.8.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
