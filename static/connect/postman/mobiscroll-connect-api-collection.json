              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"google\",\n  \"calendarId\": \"primary\",\n  \"eventId\": \"EVENT_ID_HERE\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
